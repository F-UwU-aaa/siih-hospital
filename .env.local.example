# Cadena de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BASE_DATOS
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/siih_db"

# Secreto para firmar cookies de sesión (HMAC-SHA256) — generar uno único por entorno
SESSION_SECRET="TU_SECRETO_AQUI_CAMBIA_EN_PRODUCCION"
